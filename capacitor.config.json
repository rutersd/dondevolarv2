{
  "appId": "es.dronecheck.app",
  "appName": "DroneCheck ES",
  "webDir": "www",
  "server": {
    "androidScheme": "https"
  },
  "android": {
    "allowMixedContent": true
  },
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 1500,
      "backgroundColor": "#0a0a0f",
      "androidSplashResourceName": "splash",
      "showSpinner": false
    }
  }
}
